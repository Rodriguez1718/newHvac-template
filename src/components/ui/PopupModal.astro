---
import { Image } from "astro:assets";
import { siteConfig } from "@/config/site"

interface Props {
  delay?: number;
  showOnce?: boolean;
  triggerId?: string;
}

const {
  delay = 5000,
  showOnce = true,
  triggerId = "free-scan-trigger",
} = Astro.props;
---

<div
  id="popup-modal"
  class="fixed inset-0 z-[200] hidden items-center justify-center bg-black/60 backdrop-blur-sm overflow-y-auto"
  role="dialog"
  aria-modal="true"
  aria-labelledby="popup-title"
  data-delay={delay}
  data-show-once={showOnce}
  data-trigger-id={triggerId}
>
  <div class="popup-card animate-popup-in">

    <!-- Close button -->
    <button
      id="close-popup"
      class="popup-close"
      aria-label="Close popup"
    >
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>

    <!-- Header with background pattern -->
    <div class="popup-header">
      <div class="popup-header-bg"></div>
      <div class="popup-header-content">
        <div class="popup-badge">
          <div class="popup-badge-dot"></div>
          <span>Limited Time</span>
        </div>
        <h2 id="popup-title" class="popup-header-title">$69 HVAC Diagnostic</h2>
        <p class="popup-header-subtitle">Complete system inspection & performance report</p>
      </div>
      
      <!-- Floating price circle -->
      <div class="popup-price-circle">
        <div class="popup-price-inner">
          <span class="popup-price-currency">$</span>
          <span class="popup-price-amount">69</span>
        </div>
        <div class="popup-price-label">Special Price</div>
      </div>
    </div>

    <!-- Content -->
    <div class="popup-content">
      
      <!-- Features grid -->
      <div class="popup-features-grid">
        <div class="popup-feature-card">
          <div class="popup-feature-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M9 12l2 2 4-4"/>
              <circle cx="12" cy="12" r="9"/>
            </svg>
          </div>
          <div class="popup-feature-text">
            <h4>Complete Inspection</h4>
            <p>Full system diagnostic</p>
          </div>
        </div>

        <div class="popup-feature-card">
          <div class="popup-feature-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
              <polyline points="14,2 14,8 20,8"/>
              <line x1="16" y1="13" x2="8" y2="13"/>
              <line x1="16" y1="17" x2="8" y2="17"/>
              <polyline points="10,9 9,9 8,9"/>
            </svg>
          </div>
          <div class="popup-feature-text">
            <h4>Detailed Report</h4>
            <p>Performance analysis</p>
          </div>
        </div>

        <div class="popup-feature-card">
          <div class="popup-feature-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            </svg>
          </div>
          <div class="popup-feature-text">
            <h4>No Hidden Fees</h4>
            <p>Transparent pricing</p>
          </div>
        </div>
      </div>

      <!-- Trust indicators -->
      <div class="popup-trust-bar">
        <div class="popup-trust-item">
          <svg class="popup-trust-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
          </svg>
          <span>Licensed & Insured</span>
        </div>
        <div class="popup-trust-item">
          <svg class="popup-trust-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="10"/>
            <polyline points="12,6 12,12 16,14"/>
          </svg>
          <span>Same Day Service</span>
        </div>
      </div>

      <!-- Action buttons -->
      <div class="popup-actions">
        <a href="/contact" class="popup-btn popup-btn-primary">
          <svg class="popup-btn-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
            <line x1="16" y1="2" x2="16" y2="6"/>
            <line x1="8" y1="2" x2="8" y2="6"/>
            <line x1="3" y1="10" x2="21" y2="10"/>
          </svg>
          Schedule Online
        </a>

        <a href={`tel:${siteConfig.contact.phone}`} class="popup-btn popup-btn-secondary">
          <svg class="popup-btn-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
          </svg>
          Call {siteConfig.contact.phoneFormatted}
        </a>
      </div>

      <button id="close-popup-bottom" class="popup-dismiss">No thanks, maybe later</button>
    </div>
  </div>
</div>

<script is:inline>
  function showPopup(force) {
    var popup = document.getElementById("popup-modal");
    if (!popup) return;
    if (!force && sessionStorage.getItem("popup-shown") === "true") return;
    popup.classList.remove("hidden");
    popup.classList.add("flex");
    document.body.style.overflow = "hidden";
    sessionStorage.setItem("popup-shown", "true");
  }

  function closePopup() {
    var popup = document.getElementById("popup-modal");
    if (!popup) return;
    popup.classList.add("hidden");
    popup.classList.remove("flex");
    document.body.style.overflow = "";
  }

  function initPopup() {
    var popup = document.getElementById("popup-modal");
    if (!popup) return;

    var alreadyShown = sessionStorage.getItem("popup-shown") === "true";
    var triggerId = popup.getAttribute("data-trigger-id");
    var abortController = new AbortController();
    var signal = abortController.signal;

    var closeBtn = document.getElementById("close-popup");
    var closeBtnBottom = document.getElementById("close-popup-bottom");
    if (closeBtn) closeBtn.addEventListener("click", closePopup, { signal: signal });
    if (closeBtnBottom) closeBtnBottom.addEventListener("click", closePopup, { signal: signal });
    popup.addEventListener("click", function(e) { if (e.target === popup) closePopup(); }, { signal: signal });
    document.addEventListener("keydown", function(e) {
      if (e.key === "Escape" && !popup.classList.contains("hidden")) closePopup();
    }, { signal: signal });

    if (triggerId) {
      var trigger = document.getElementById(triggerId);
      if (trigger) trigger.addEventListener("click", function(e) {
        e.preventDefault();
        showPopup(true);
      }, { signal: signal });
    }

    var delay = parseInt(popup.getAttribute("data-delay") || "0") || 0;
    if (delay > 0 && window.innerWidth >= 768 && !alreadyShown) {
      setTimeout(function() { if (window.innerWidth >= 768) showPopup(false); }, delay);
    }

    document.addEventListener('astro:before-swap', function() {
      closePopup();
      abortController.abort();
    }, { once: true });
  }

  document.addEventListener("astro:page-load", initPopup);
</script>

<style>
  @keyframes popup-in {
    from { opacity: 0; transform: translateY(30px) scale(0.96); }
    to { opacity: 1; transform: translateY(0) scale(1); }
  }
  .animate-popup-in {
    animation: popup-in 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  /* ─── Card ─── */
  .popup-card {
    position: relative;
    width: 100%;
    max-width: 480px;
    margin: 1.5rem;
    background: white;
    border-radius: 0;
    overflow: hidden;
    box-shadow: 0 25px 60px rgba(0, 0, 0, 0.4), 0 0 0 1px rgba(0, 0, 0, 0.1);
    border: 3px solid var(--brand-highlight);
  }

  /* Close */
  .popup-close {
    position: absolute;
    top: 1rem;
    right: 1rem;
    z-index: 30;
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--brand-primary);
    border: 2px solid var(--brand-highlight);
    border-radius: 0;
    color: white;
    cursor: pointer;
    transition: all 0.2s ease;
  }
  .popup-close:hover {
    background: var(--brand-highlight);
    color: var(--brand-primary);
    transform: scale(1.1);
  }

  /* ─── Header Section ─── */
  .popup-header {
    position: relative;
    padding: 2.5rem 2rem 1.5rem;
    background: var(--brand-primary);
    overflow: hidden;
  }

  .popup-header-bg {
    position: absolute;
    inset: 0;
    background: url('/images/aircon.png') center/cover no-repeat;
    opacity: 0.08;
    z-index: 1;
  }

  .popup-header-content {
    position: relative;
    z-index: 2;
    text-align: center;
  }

  .popup-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    background: var(--brand-highlight);
    border: none;
    border-radius: 0;
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--brand-primary);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 1rem;
    clip-path: polygon(0 0, calc(100% - 8px) 0, 100% 100%, 8px 100%);
  }

  .popup-badge-dot {
    width: 6px;
    height: 6px;
    background: var(--brand-primary);
    border-radius: 0;
    animation: pulse 2s ease-in-out infinite;
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(0.8); }
  }

  .popup-header-title {
    font-size: 1.75rem;
    font-weight: 800;
    color: white;
    margin: 0 0 0.5rem;
    text-transform: uppercase;
    letter-spacing: -0.02em;
    line-height: 1.1;
  }

  .popup-header-subtitle {
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.8);
    margin: 0;
    line-height: 1.4;
  }

  /* Floating price circle */
  .popup-price-circle {
    position: absolute;
    top: -30px;
    right: 1.5rem;
    z-index: 3;
    text-align: center;
  }

  .popup-price-inner {
    width: 80px;
    height: 80px;
    background: var(--brand-highlight);
    border-radius: 0;
    border: 3px solid var(--brand-primary);
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.3);
    margin-bottom: 0.5rem;
    clip-path: polygon(15% 0%, 100% 0%, 85% 100%, 0% 100%);
  }

  .popup-price-currency {
    font-size: 1rem;
    font-weight: 700;
    color: var(--brand-primary);
    margin-right: 2px;
  }

  .popup-price-amount {
    font-size: 1.75rem;
    font-weight: 800;
    color: var(--brand-primary);
    letter-spacing: -0.02em;
  }

  .popup-price-label {
    font-size: 0.65rem;
    font-weight: 700;
    color: var(--brand-highlight);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    background: var(--brand-primary);
    padding: 0.25rem 0.5rem;
    border: 1px solid var(--brand-highlight);
  }

  /* ─── Content Section ─── */
  .popup-content {
    padding: 2rem;
  }

  /* Features grid */
  .popup-features-grid {
    display: grid;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .popup-feature-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem;
    background: white;
    border: 2px solid var(--brand-primary);
    border-radius: 0;
    transition: all 0.2s ease;
    position: relative;
  }
  .popup-feature-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 4px;
    height: 100%;
    background: var(--brand-highlight);
    transform: scaleY(0);
    transform-origin: top;
    transition: transform 0.3s ease;
  }
  .popup-feature-card:hover::before {
    transform: scaleY(1);
  }
  .popup-feature-card:hover {
    background: var(--brand-tertiary);
    border-color: var(--brand-highlight);
    transform: translateX(4px);
  }

  .popup-feature-icon {
    width: 40px;
    height: 40px;
    background: var(--brand-primary);
    border: 2px solid var(--brand-highlight);
    border-radius: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: all 0.2s ease;
  }
  .popup-feature-card:hover .popup-feature-icon {
    background: var(--brand-highlight);
    border-color: var(--brand-primary);
  }

  .popup-feature-icon svg {
    width: 20px;
    height: 20px;
    color: white;
    transition: color 0.2s ease;
  }
  .popup-feature-card:hover .popup-feature-icon svg {
    color: var(--brand-primary);
  }

  .popup-feature-text h4 {
    font-size: 0.875rem;
    font-weight: 800;
    color: var(--brand-primary);
    margin: 0 0 0.25rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .popup-feature-text p {
    font-size: 0.75rem;
    color: var(--brand-secondary);
    margin: 0;
    font-weight: 500;
  }

  /* Trust bar */
  .popup-trust-bar {
    display: flex;
    justify-content: center;
    gap: 2rem;
    padding: 1rem;
    background: var(--brand-primary);
    border: 2px solid var(--brand-highlight);
    border-radius: 0;
    margin-bottom: 1.5rem;
    position: relative;
  }
  .popup-trust-bar::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: var(--brand-highlight);
  }

  .popup-trust-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.75rem;
    font-weight: 700;
    color: white;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .popup-trust-icon {
    width: 16px;
    height: 16px;
    color: var(--brand-highlight);
    flex-shrink: 0;
  }

  /* Action buttons */
  .popup-actions {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }

  .popup-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    padding: 1rem 1.5rem;
    font-size: 0.875rem;
    font-weight: 700;
    text-decoration: none;
    border-radius: 0;
    transition: all 0.3s ease;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    border: 2px solid transparent;
    position: relative;
    overflow: hidden;
  }
  .popup-btn::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
    transition: left 0.5s ease;
  }
  .popup-btn:hover::before {
    left: 100%;
  }

  .popup-btn-icon {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
  }

  .popup-btn-primary {
    background: var(--brand-highlight);
    color: var(--brand-primary);
    border-color: var(--brand-primary);
    box-shadow: 0 4px 0 var(--brand-primary);
  }
  .popup-btn-primary:hover {
    transform: translateY(2px);
    box-shadow: 0 2px 0 var(--brand-primary);
  }

  .popup-btn-secondary {
    background: var(--brand-primary);
    color: white;
    border-color: var(--brand-highlight);
    box-shadow: 0 4px 0 var(--brand-highlight);
  }
  .popup-btn-secondary:hover {
    transform: translateY(2px);
    box-shadow: 0 2px 0 var(--brand-highlight);
  }

  .popup-dismiss {
    display: block;
    width: 100%;
    background: none;
    border: none;
    color: rgba(0, 0, 0, 0.4);
    font-size: 0.75rem;
    cursor: pointer;
    padding: 0.75rem;
    transition: color 0.2s;
    text-align: center;
  }
  .popup-dismiss:hover {
    color: var(--brand-primary);
  }

  /* ─── Mobile adjustments ─── */
  @media (max-width: 640px) {
    .popup-card {
      max-width: 360px;
      margin: 1rem;
    }
    
    .popup-header {
      padding: 2rem 1.5rem 1.25rem;
    }
    
    .popup-header-title {
      font-size: 1.5rem;
    }
    
    .popup-price-circle {
      right: 1rem;
    }
    
    .popup-price-inner {
      width: 70px;
      height: 70px;
    }
    
    .popup-price-amount {
      font-size: 1.5rem;
    }
    
    .popup-content {
      padding: 1.5rem;
    }
    
    .popup-trust-bar {
      flex-direction: column;
      gap: 0.75rem;
      text-align: center;
    }
  }
</style>
