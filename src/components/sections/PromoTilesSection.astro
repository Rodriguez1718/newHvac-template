---
import { siteConfig, getLocationText } from "@/config/site"

interface PromoTile {
  type: "maintenance" | "financing" | "emergency";
  tag?: string;
  title?: string;
  priceLabel?: string[];
  headline?: string[];
  subtext?: string;
  discount?: string;
  subheadline?: string[];
  phone?: string;
  buttonText: string;
  buttonHref?: string;
  bgImage?: string;
}

interface Props {
  tiles: PromoTile[];
}

const { tiles: rawTiles } = Astro.props;
const tiles = rawTiles.map(tile => ({
  ...tile,
  phone: tile.phone || siteConfig.contact.phoneFormatted,
  title: tile.title ? getLocationText(tile.title) : tile.title,
}));
---

<section class="pt-section">
  <div class="container mx-auto px-6 md:px-12 lg:px-16 py-20 md:py-28">
    <div class="pt-grid" data-animate-stagger>

      {tiles.map((tile, index) => (
        <div class:list={["pt-card", { "pt-card--featured": index === 1 }]}>

          {/* Diagonal corner badge */}
          <div class="pt-corner">
            <span class="pt-corner-label">
              {tile.tag || (tile.type === "maintenance" && "PLAN") || (tile.type === "financing" && "FINANCING") || (tile.type === "emergency" && "24/7 SERVICE")}
            </span>
          </div>

          {/* Content wrapper */}
          <div class="pt-card-inner">

            {/* Main content */}
            <div class="pt-content">

              {tile.type === "maintenance" && (
                <div>
                  {tile.title && (
                    <h3 class="pt-title pt-bars-target">{tile.title}</h3>
                  )}
                  {tile.priceLabel && (
                    <div class="pt-price-block">
                      <span class="pt-price-label">{tile.priceLabel[0]}</span>
                      <span class="pt-price-value">{tile.priceLabel[1]}</span>
                      <span class="pt-price-label">{tile.priceLabel[2]}</span>
                    </div>
                  )}
                  <p class="pt-note">Priority scheduling included</p>
                </div>
              )}

              {tile.type === "financing" && (
                <div>
                  {tile.headline && (
                    <div class="pt-headline-group pt-bars-target">
                      {tile.headline.map((line) => (
                        <p class="pt-headline">{line}</p>
                      ))}
                    </div>
                  )}
                  {tile.subtext && (
                    <p class="pt-subtext">{tile.subtext}</p>
                  )}
                  <div class="pt-features">
                    <div class="pt-feature">
                      <span class="pt-feature-dot"></span>
                      <span>Quick approval process</span>
                    </div>
                    <div class="pt-feature">
                      <span class="pt-feature-dot"></span>
                      <span>Flexible payment options</span>
                    </div>
                  </div>
                </div>
              )}

              {tile.type === "emergency" && (
                <div>
                  {tile.discount && (
                    <p class="pt-discount pt-bars-target">{tile.discount}</p>
                  )}
                  {tile.subheadline && (
                    <div class="pt-subheadline-group">
                      {tile.subheadline.map((line) => (
                        <p class="pt-subheadline">{line}</p>
                      ))}
                    </div>
                  )}
                  <div class="pt-checklist">
                    <div class="pt-check-item">
                      <span class="pt-feature-dot"></span>
                      <span>System inspection</span>
                    </div>
                    <div class="pt-check-item">
                      <span class="pt-feature-dot"></span>
                      <span>Filter replacement</span>
                    </div>
                    <div class="pt-check-item">
                      <span class="pt-feature-dot"></span>
                      <span>Performance report</span>
                    </div>
                  </div>
                  <p class="pt-note">Limited time offer</p>
                </div>
              )}
            </div>

            {/* CTA */}
            <div class="pt-cta">
              <a
                href={tile.buttonHref || "/contact"}
                class="pt-btn"
                aria-label={`${tile.buttonText} - ${tile.title || tile.headline?.join(' ') || tile.discount || 'promo'}`}
              >
                {tile.buttonText}
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                  <path d="M5 12h14M12 5l7 7-7 7"/>
                </svg>
              </a>
              <a
                href={`tel:${tile.phone.replace(/[^0-9]/g, '')}`}
                class="pt-phone"
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/>
                </svg>
                {tile.phone}
              </a>
            </div>
          </div>

          {/* Bottom horizontal text - outside card-inner */}
          <div class="pt-bottom-label">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="pt-scissors-icon">
              <circle cx="6" cy="6" r="3"/><circle cx="6" cy="18" r="3"/><line x1="20" y1="4" x2="8.12" y2="15.88"/><line x1="14.47" y1="14.48" x2="20" y2="20"/><line x1="8.12" y1="8.12" x2="12" y2="12"/>
            </svg>
            <span class="pt-bottom-text">GREAT DISCOUNT</span>
          </div>

        </div>
      ))}

    </div>
  </div>
</section>

<style>
  .pt-section {
    position: relative;
    background: var(--brand-primary);
  }
  .pt-section::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: url('/images/coolair.png');
    background-size: 110%;
    background-position: center;
    background-repeat: no-repeat;
    opacity: 0.15;
    pointer-events: none;
    z-index: 0;
  }

  /* ─── Grid ─── */
  .pt-grid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    max-width: 76rem;
    margin: 0 auto;
  }

  @media (min-width: 640px) {
    .pt-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 1.5rem;
    }
  }

  @media (min-width: 1024px) {
    .pt-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 2rem;
    }
  }

  /* ─── Card ─── */
  .pt-card {
    position: relative;
    background: #ffffff;
    overflow: hidden;
    transition: all 0.25s ease;
    display: flex;
    flex-direction: column;
  }
  .pt-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.1);
  }

  /* Featured card - solid border */
  .pt-card--featured {
    border: 3px solid var(--brand-highlight);
    border-style: solid;
  }

  @media (min-width: 1024px) {
    .pt-card--featured {
      transform: scale(1.08);
      z-index: 2;
    }
    .pt-card--featured:hover {
      transform: scale(1.08) translateY(-2px);
    }
  }

  /* ─── Diagonal Corner ─── */
  .pt-corner {
    position: absolute;
    top: 0;
    left: 0;
    width: 0;
    height: 0;
    border-style: solid;
    border-width: 110px 110px 0 0;
    border-color: var(--brand-highlight) transparent transparent transparent;
    z-index: 5;
    overflow: visible;
  }
  .pt-corner-label {
    position: absolute;
    top: -89px;
    left: 19px;
    color: #ffffff;
    font-size: 0.6rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    transform: rotate(-45deg);
    line-height: 1;
    max-width: 90px;
    overflow: visible;
  }

  /* ─── Card Inner ─── */
  .pt-card-inner {
    position: relative;
    padding: 4rem 2rem 2rem 2rem;
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  @media (min-width: 768px) {
    .pt-card-inner {
      padding: 4rem 2.5rem 2.5rem 2.5rem;
    }
  }

  /* ─── Left Bars ─── */
  .pt-bars {
    position: absolute;
    left: 3rem;
    top: 4rem;
    display: flex;
    gap: 0.5rem;
    z-index: 1;
    pointer-events: none;
  }
  .pt-bar-main,
  .pt-bar-secondary {
    background: var(--brand-highlight);
  }
  .pt-bar-main {
    width: 8px;
    height: var(--bar-height, 70px);
  }
  .pt-bar-secondary {
    width: 5px;
    height: var(--bar-height, 70px);
  }

  /* Calculate bar height based on content type */
  .pt-card:has(.pt-title) .pt-bars {
    --bar-height: 60px;
  }
  .pt-card:has(.pt-headline-group) .pt-bars {
    --bar-height: 90px;
  }
  .pt-card:has(.pt-discount) .pt-bars {
    --bar-height: 110px;
  }

  /* ─── Content ─── */
  .pt-content {
    flex: 1;
    padding-left: 2rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .pt-title {
    font-size: 0.95rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    line-height: 1.25;
    color: #2d2d2d;
    margin-bottom: 1.5rem;
  }

  /* ─── Price Block ─── */
  .pt-price-block {
    background: #fafafa;
    border: 1px solid #e0e0e0;
    padding: 1.25rem 1.5rem;
    margin-bottom: 1rem;
  }
  .pt-price-label {
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: #888;
    display: block;
  }
  .pt-price-value {
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 2.5rem;
    font-weight: 900;
    line-height: 1.1;
    color: var(--brand-highlight);
    display: block;
    margin: 0.25rem 0;
  }

  /* ─── Headline ─── */
  .pt-headline-group {
    margin-bottom: 0.75rem;
  }
  .pt-headline {
    font-family: 'Inter', system-ui, sans-serif;
    font-size: clamp(1.5rem, 3.5vw, 2rem);
    font-weight: 900;
    text-transform: uppercase;
    line-height: 0.95;
    color: #1a1a1a;
    letter-spacing: -0.02em;
  }
  .pt-subtext {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #888;
    margin-bottom: 1.25rem;
  }

  /* ─── Features ─── */
  .pt-features {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    margin-top: 1.25rem;
  }
  .pt-feature {
    display: flex;
    align-items: flex-start;
    gap: 0.625rem;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--brand-secondary);
    line-height: 1.4;
  }
  .pt-feature-dot {
    width: 6px;
    height: 6px;
    background: var(--brand-highlight);
    flex-shrink: 0;
    margin-top: 0.35rem;
  }

  /* ─── Discount ─── */
  .pt-discount {
    font-family: 'Inter', system-ui, sans-serif;
    font-size: clamp(2.75rem, 5.5vw, 3.75rem);
    font-weight: 900;
    line-height: 0.9;
    color: var(--brand-highlight);
    margin-bottom: 0.5rem;
  }
  .pt-subheadline-group {
    margin-bottom: 1.25rem;
  }
  .pt-subheadline {
    font-size: 0.95rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.01em;
    color: #2d2d2d;
    line-height: 1.3;
  }

  /* ─── Checklist ─── */
  .pt-checklist {
    background: #fafafa;
    border: 1px solid #e0e0e0;
    padding: 1rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }
  .pt-check-item {
    display: flex;
    align-items: flex-start;
    gap: 0.625rem;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--brand-secondary);
  }

  /* ─── Note ─── */
  .pt-note {
    font-size: 0.65rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #aaa;
    margin-top: 0.5rem;
  }

  /* ─── CTA ─── */
  .pt-cta {
    padding-left: 2rem;
    padding-top: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .pt-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.875rem 1.75rem;
    background: var(--brand-highlight);
    color: #ffffff;
    font-weight: 800;
    font-size: 0.7rem;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    transition: all 0.25s ease;
    align-self: flex-start;
  }
  .pt-btn:hover {
    background: color-mix(in srgb, var(--brand-highlight) 90%, black);
    transform: translateX(3px);
  }
  .pt-btn svg {
    transition: transform 0.25s ease;
  }
  .pt-btn:hover svg {
    transform: translateX(3px);
  }

  .pt-phone {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.75rem;
    font-weight: 700;
    color: #777;
    text-decoration: none;
    transition: color 0.25s ease;
  }
  .pt-phone:hover {
    color: var(--brand-highlight);
  }

  /* ─── Bottom Label ─── */
  .pt-bottom-label {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    padding: 0.75rem 2rem;
    margin: 0 1rem;
    font-size: 0.65rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--brand-highlight);
    border-top: 1px dashed #d0d0d0;
    position: relative;
  }
  
  .pt-scissors-icon {
    color: var(--brand-highlight);
    position: absolute;
    left: 0;
    top: -12px;
    background: #ffffff;
    padding: 0 0.25rem;
  }
  
  .pt-bottom-text {
    display: inline-block;
  }

  /* ─── Responsive ─── */
  @media (max-width: 639px) {
    .pt-card-inner {
      padding: 3.5rem 1.25rem 1.5rem 1.25rem;
    }
    .pt-bars {
      left: 1.25rem;
      top: 3.5rem;
      gap: 0.375rem;
    }
    .pt-bar-main {
      width: 6px;
    }
    .pt-bar-secondary {
      width: 4px;
    }
    .pt-content {
      padding-left: 1.25rem;
    }
    .pt-cta {
      padding-left: 1.25rem;
      padding-top: 1.25rem;
    }
    .pt-bottom-label {
      padding: 0.625rem 1.25rem;
      margin: 0 0.625rem;
      font-size: 0.6rem;
    }
    .pt-corner {
      border-width: 90px 90px 0 0;
    }
    .pt-corner-label {
      top: -70px;
      left: 14px;
      font-size: 0.55rem;
    }
    .pt-price-value {
      font-size: 2rem;
    }
    .pt-headline {
      font-size: clamp(1.25rem, 5vw, 1.75rem);
    }
    .pt-discount {
      font-size: clamp(2.25rem, 8vw, 3rem);
    }
  }

  @media (min-width: 640px) and (max-width: 1023px) {
    .pt-card-inner {
      padding: 3.75rem 2rem 2rem 2rem;
    }
    .pt-bars {
      left: 2rem;
      top: 3.75rem;
    }
    .pt-content {
      padding-left: 1.75rem;
    }
    .pt-cta {
      padding-left: 1.75rem;
    }
  }
</style>
