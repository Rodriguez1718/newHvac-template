---
interface Service {
  title: string;
  description: string;
  href?: string;
}

interface ServiceCategory {
  title: string;
  services: Service[];
}

interface Props {
  title: string;
  description: string;
  categories: ServiceCategory[];
  badge?: string;
}

const { title, description, categories, badge = "Our Services" } = Astro.props;
---

<section class="ss-section">
  <div class="ss-body">
    <div class="container mx-auto px-6 md:px-12 lg:px-16 py-20 md:py-28">

    <!-- Header -->
    <div class="ss-header" data-animate="fade-up">
      <div class="ss-eyebrow">
        <span class="ss-eyebrow-text">{badge}</span>
      </div>

      <div class="ss-header-grid">
        <h2 class="ss-title">{title}</h2>
        <p class="ss-desc" set:html={description} />
      </div>
    </div>

    <!-- Categories -->
    <div class="ss-categories" data-animate-stagger>
      {categories.map((category) => (
        <div class="ss-category">
          <div class="ss-cat-header">
            <div class="ss-cat-line"></div>
            <h3 class="ss-cat-title">{category.title}</h3>
          </div>

          <div class="ss-grid">
            {category.services.map((service, serviceIndex) => {
              // Always make cards clickable - use href if provided, otherwise default to /contact
              const href = service.href || '/contact';
              const cardNumber = String(serviceIndex + 1).padStart(2, '0');
              return (
                <a
                  href={href}
                  class="ss-card group"
                >
                  <span class="ss-card-strip"></span>

                  <div class="ss-card-inner">
                    <h4 class="ss-card-title">{service.title}</h4>
                    <p class="ss-card-desc" set:html={service.description} />

                    <div class="ss-arrow">
                      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M5 12h14M12 5l7 7-7 7" />
                      </svg>
                    </div>
                  </div>

                  <span class="ss-card-number">{cardNumber}</span>
                </a>
              );
            })}
          </div>
        </div>
      ))}
      </div>
    </div>
  </div>
</section>

<style>
  .ss-section {
    position: relative;
    background: var(--background);
  }
  .ss-section::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: url('/images/aircon.png');
    background-size: 65%;
    background-position: center;
    background-repeat: no-repeat;
    opacity: 0.35;
    pointer-events: none;
    z-index: 0;
  }

  @media (max-width: 1024px) {
    .ss-section::before {
      background-size: 75%;
    }
  }

  @media (max-width: 640px) {
    .ss-section::before {
      background-size: 90%;
    }
  }

  .ss-body {
    background: rgba(255, 255, 255, 0.75);
    padding: 0;
    position: relative;
    z-index: 1;
  }

  /* ─── Header ─── */
  .ss-header {
    margin-bottom: 3rem;
  }
  .ss-eyebrow {
    margin-bottom: 1.5rem;
  }
  .ss-eyebrow-text {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--brand-highlight);
    display: inline-block;
    padding: 0.4rem 1rem;
    background: var(--brand-primary);
    border-left: 3px solid var(--brand-highlight);
  }

  .ss-header-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }
  @media (min-width: 1024px) {
    .ss-header-grid {
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
      align-items: start;
    }
  }

  .ss-title {
    font-size: 2rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    line-height: 1.1;
    color: var(--brand-primary);
  }
  @media (min-width: 768px) {
    .ss-title { font-size: 2.5rem; }
  }

  .ss-desc {
    font-size: 0.95rem;
    line-height: 1.75;
    color: var(--brand-secondary);
  }

  /* ─── Categories ─── */
  .ss-categories {
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  .ss-cat-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid rgba(0, 0, 0, 0.06);
  }
  .ss-cat-line {
    width: 3px;
    height: 24px;
    background: var(--brand-highlight);
    flex-shrink: 0;
  }
  .ss-cat-title {
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--brand-primary);
  }

  /* ─── Cards Grid ─── */
  .ss-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }
  @media (min-width: 1024px) {
    .ss-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* ─── Card ─── */
  .ss-card {
    position: relative;
    display: block;
    background: white;
    border: 1px solid rgba(0, 0, 0, 0.18);
    overflow: hidden;
    transition: all 0.35s ease;
    text-decoration: none;
    color: inherit;
  }
  .ss-card:hover {
    border-color: var(--brand-highlight);
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.18);
  }

  .ss-card-strip {
    position: absolute;
    top: 0;
    left: 0;
    width: 3px;
    height: 0;
    background: var(--brand-highlight);
    transition: height 0.35s ease;
  }
  .ss-card:hover .ss-card-strip {
    height: 100%;
  }

  .ss-card-inner {
    padding: 1.75rem 1.5rem;
    display: flex;
    flex-direction: column;
    min-height: 140px;
  }

  .ss-card-title {
    font-size: 1rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    color: var(--brand-primary);
    margin-bottom: 0.5rem;
    line-height: 1.25;
    transition: color 0.3s ease;
  }

  .ss-card-desc {
    font-size: 0.85rem;
    line-height: 1.6;
    color: var(--brand-secondary);
    margin-bottom: auto;
    padding-bottom: 1rem;
  }

  .ss-arrow {
    width: 32px;
    height: 32px;
    display: flex !important;
    align-items: center;
    justify-content: center;
    background: red !important;
    color: white !important;
    transition: all 0.3s ease;
    flex-shrink: 0;
    margin-top: auto;
  }
  .ss-card:hover .ss-arrow {
    background: var(--brand-highlight);
    color: var(--brand-primary);
    transform: translateX(4px);
  }

  .ss-card-number {
    position: absolute;
    bottom: -0.75rem;
    right: 1rem;
    font-size: 6rem;
    font-weight: 900;
    line-height: 1;
    font-family: 'Arial', 'Helvetica', sans-serif;
    color: transparent;
    -webkit-text-stroke: 2px rgba(0, 0, 0, 0.08);
    text-stroke: 2px rgba(0, 0, 0, 0.08);
    pointer-events: none;
    user-select: none;
    transition: -webkit-text-stroke 0.3s ease, text-stroke 0.3s ease, color 0.3s ease;
  }
  .ss-card:hover .ss-card-number {
    color: rgba(0, 0, 0, 0.08);
    -webkit-text-stroke: 0;
    text-stroke: 0;
  }

  /* ─── Responsive ─── */
  @media (max-width: 640px) {
    .ss-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
