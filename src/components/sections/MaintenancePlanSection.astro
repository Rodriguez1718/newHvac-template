---
interface IncludedItem {
  title: string;
  description: string;
}

interface Props {
  title: string;
  description: string;
  includedItems: IncludedItem[];
  benefits: string[];
  buttonText?: string;
  buttonHref?: string;
  eyebrow?: string;
}

const { title, description, includedItems, benefits, buttonText = "VIEW PLANS", buttonHref = "/maintenance-plans", eyebrow } = Astro.props;
---

<section class="mp-section">
  <!-- Airflow pattern background -->
  <svg class="mp-airflow-bg" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 800" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
    <defs>
      <pattern id="maintenance-airflow-grid" width="200" height="200" patternUnits="userSpaceOnUse">
        <path d="M 0 100 Q 50 80, 100 100 T 200 100" stroke="currentColor" stroke-width="1.5" fill="none" opacity="0.4"/>
        <path d="M 0 150 Q 50 130, 100 150 T 200 150" stroke="currentColor" stroke-width="1.5" fill="none" opacity="0.3"/>
        <path d="M 100 0 Q 80 50, 100 100 T 100 200" stroke="currentColor" stroke-width="1.5" fill="none" opacity="0.35"/>
      </pattern>
    </defs>
    <rect width="100%" height="100%" fill="url(#maintenance-airflow-grid)"/>
    <path d="M 0 200 Q 300 150, 600 200 T 1200 200" stroke="currentColor" stroke-width="2" fill="none" opacity="0.25"/>
    <path d="M 0 400 Q 300 350, 600 400 T 1200 400" stroke="currentColor" stroke-width="2" fill="none" opacity="0.2"/>
    <path d="M 0 600 Q 300 550, 600 600 T 1200 600" stroke="currentColor" stroke-width="2" fill="none" opacity="0.15"/>
  </svg>

  <div class="container mx-auto px-6 md:px-12 lg:px-16 py-20 md:py-28">
    
    <!-- Header -->
    <div class="mp-header" data-animate="fade-scale">
      {eyebrow && (
        <div class="mp-badge">
          <span class="mp-badge-text">{eyebrow}</span>
        </div>
      )}
      <h2 class="mp-title">{title}</h2>
      <p class="mp-desc" set:html={description} />
    </div>

    <!-- Cards grid -->
    <div class="mp-grid" data-animate-stagger>
      {includedItems.map((item, index) => {
        const icons = [
          `<path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/>
           <circle cx="12" cy="12" r="3"/>`,
          `<path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/>`,
          `<path d="M9.59 4.59A2 2 0 1 1 11 8H2m10.59 11.41A2 2 0 1 0 14 16H2m15.73-8.27A2.5 2.5 0 1 1 19.5 12H2"/>`,
          `<path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>`
        ];

        return (
          <div class="mp-card">
            <div class="mp-card-accent"></div>
            
            <div class="mp-card-left">
              <div class="mp-number">{String(index + 1).padStart(2, '0')}</div>
              <div class="mp-icon-wrap">
                <svg xmlns="http://www.w3.org/2000/svg" class="mp-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <Fragment set:html={icons[index]} />
                </svg>
              </div>
            </div>

            <div class="mp-card-right">
              <h3 class="mp-card-title">{item.title}</h3>
              <p class="mp-card-desc" set:html={item.description} />
              <a href={buttonHref} class="mp-card-link" aria-label={`View details about ${item.title}`}>
                Learn More
                <svg xmlns="http://www.w3.org/2000/svg" class="mp-link-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                  <path d="M5 12h14M12 5l7 7-7 7"/>
                </svg>
              </a>
            </div>
          </div>
        );
      })}
    </div>
  
    <!-- CTA Button -->
    <div class="mp-cta-center">
      <a href={buttonHref} class="mp-btn">
        {buttonText}
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    </div>

  </div>
</section>

<style>
  .mp-section {
    background: var(--brand-tertiary);
    position: relative;
    overflow: hidden;
  }

  /* ─── Airflow Background ─── */
  .mp-airflow-bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    color: var(--brand-primary);
    opacity: 0.08;
    pointer-events: none;
    z-index: 0;
  }

  .mp-section > .container {
    position: relative;
    z-index: 1;
  }

  /* ─── Header ─── */
  .mp-header {
    text-align: center;
    margin-bottom: 4rem;
    max-width: 48rem;
    margin-left: auto;
    margin-right: auto;
  }

  .mp-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    background: var(--brand-primary);
    border-left: 3px solid var(--brand-highlight);
    margin-bottom: 1.5rem;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(0.8); }
  }
  .mp-badge-text {
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--brand-highlight);
  }

  .mp-title {
    font-size: 2rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    line-height: 1.1;
    color: var(--brand-primary);
    margin-bottom: 1.25rem;
  }
  @media (min-width: 768px) {
    .mp-title { font-size: 2.5rem; }
  }

  .mp-desc {
    font-size: 0.95rem;
    line-height: 1.75;
    color: var(--brand-secondary);
  }

  /* ─── Cards Grid ─── */
  .mp-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    margin-bottom: 0;
  }
  @media (min-width: 768px) {
    .mp-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  /* ─── Card ─── */
  .mp-card {
    background: white;
    display: flex;
    gap: 0;
    position: relative;
    overflow: hidden;
    transition: all 0.35s ease;

    border: 1px solid rgba(0,0,0,0.08);
    min-height: 200px;
  }
  .mp-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(0,0,0,0.12);
    border-color: var(--brand-highlight);
  }

  /* Left accent strip */
  .mp-card-accent {
    position: absolute;
    left: 0;
    top: 0;
    height: 0;
    width: 4px;
    background: var(--brand-highlight);
    transition: height 0.35s ease;
    z-index: 10;
  }
  .mp-card:hover .mp-card-accent {
    height: 100%;
  }

  /* Left side: Number + Icon */
  .mp-card-left {
    flex-shrink: 0;
    width: 140px;
    background: var(--brand-primary);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    padding: 2rem 1rem;
    position: relative;
  }

  .mp-number {
    font-size: 2.5rem;
    font-weight: 900;
    color: rgba(255, 255, 255, 0.15);
    line-height: 1;
    transition: all 0.3s ease;
  }
  .mp-card:hover .mp-number {
    color: var(--brand-highlight);
    -webkit-text-stroke: none;
    text-stroke: none;
    transform: scale(1.1);
  }

  .mp-icon-wrap {
    width: 56px;
    height: 56px;
    background: rgba(255, 255, 255, 0.08);
    border: 2px solid rgba(255, 255, 255, 0.15);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
  }
  .mp-card:hover .mp-icon-wrap {
    background: var(--brand-highlight);
    border-color: var(--brand-highlight);
    transform: rotate(5deg) scale(1.05);
  }

  .mp-icon {
    width: 28px;
    height: 28px;
    color: var(--brand-highlight);
    transition: color 0.3s ease;
  }
  .mp-card:hover .mp-icon {
    color: var(--brand-primary);
  }

  /* Right side: Content */
  .mp-card-right {
    flex: 1;
    padding: 2rem 2rem 2rem 2.5rem;
    display: flex;
    flex-direction: column;
  }

  .mp-card-title {
    font-size: 1.15rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    color: var(--brand-primary);
    margin-bottom: 0.75rem;
    line-height: 1.25;
  }

  .mp-card-desc {
    font-size: 0.875rem;
    line-height: 1.65;
    color: var(--brand-secondary);
    margin-bottom: 1.25rem;
    flex: 1;
  }

  .mp-card-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--brand-primary);
    text-decoration: none;
    transition: all 0.3s ease;
    width: fit-content;
  }
  .mp-card:hover .mp-card-link {
    color: var(--brand-highlight);
  }

  .mp-link-icon {
    width: 14px;
    height: 14px;
    transition: transform 0.3s ease;
  }
  .mp-card:hover .mp-link-icon {
    transform: translateX(4px);
  }

  /* ─── CTA Center ─── */
  .mp-cta-center {
    text-align: center;
    margin-top: 3rem;
  }

  .mp-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    padding: 0.7rem 1.75rem;
    background: var(--brand-highlight);
    color: #0a0a0a;
    font-weight: 700;
    font-size: 0.8rem;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    transition: all 0.3s ease;
    cursor: pointer;
  }
  .mp-btn:hover {
    filter: brightness(1.08);
    transform: translateX(4px);
  }
  .mp-btn svg {
    transition: transform 0.3s ease;
  }
  .mp-btn:hover svg {
    transform: translateX(4px);
  }

  /* ─── Responsive ─── */
  @media (max-width: 768px) {
    .mp-card {
      flex-direction: column;
    }
    .mp-card-left {
      width: 100%;
      flex-direction: row;
      padding: 1.5rem;
      justify-content: flex-start;
    }
    .mp-card-right {
      padding: 1.5rem;
    }
  }
</style>
