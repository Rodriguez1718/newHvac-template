---
import { getLocationText } from "@/config/site"

interface Plan {
  ribbon: string;
  ribbonColor?: "great" | "better" | "best";
  title: string;
  price: string;
  period?: string;
  features: string[];
}

interface Props {
  title: string;
  description: string;
  plans: Plan[];
}

const { title: rawTitle, description: rawDescription, plans } = Astro.props;

const title = getLocationText(rawTitle);
const description = getLocationText(rawDescription);

const bestIndex = plans.findIndex(p => p.ribbonColor === "best");
---

<section class="pp-section">
  <div class="container mx-auto px-6 md:px-12 lg:px-16 py-20 md:py-28">

    <!-- Header -->
    <div class="pp-header" data-animate="fade-up">
      <div class="pp-eyebrow">
        <span class="pp-eyebrow-text">Plans</span>
      </div>
      <h2 class="pp-title">{title}</h2>
      <div class="pp-divider"></div>
      <p class="pp-desc" set:html={description} />
    </div>

    <!-- Plans grid -->
    <div class="pp-grid" data-animate-stagger>
      {plans.map((plan, i) => (
        <div class:list={["pp-card", { "pp-card--featured": i === bestIndex }]}>

          {/* Diagonal corner badge */}
          <div class="pp-corner">
            <span class="pp-corner-label">{plan.ribbon}</span>
          </div>

          {/* Content wrapper */}
          <div class="pp-card-inner">

            {/* Main content */}
            <div class="pp-content">
              <h3 class="pp-plan-title">{plan.title}</h3>

              {/* Price */}
              <div class="pp-price-block">
                <span class="pp-price">{plan.price}</span>
                {plan.period && <span class="pp-period">{plan.period}</span>}
              </div>

              <div class="pp-sep"></div>

              {/* Features */}
              <ul class="pp-features">
                {plan.features.map((feature) => (
                  <li class="pp-feature">
                    <span class="pp-feature-dot"></span>
                    <span>{feature}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>

          {/* Bottom label with scissors */}
          <div class="pp-bottom-label">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="pp-scissors-icon">
              <circle cx="6" cy="6" r="3"/><circle cx="6" cy="18" r="3"/><line x1="20" y1="4" x2="8.12" y2="15.88"/><line x1="14.47" y1="14.48" x2="20" y2="20"/><line x1="8.12" y1="8.12" x2="12" y2="12"/>
            </svg>
            <span class="pp-bottom-text">GREAT VALUE</span>
          </div>

        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .pp-section {
    background: var(--brand-primary);
  }

  /* ─── Header ─── */
  .pp-header {
    text-align: center;
    margin-bottom: 3.5rem;
    max-width: 48rem;
    margin-left: auto;
    margin-right: auto;
  }
  .pp-eyebrow {
    margin-bottom: 1.25rem;
  }
  .pp-eyebrow-text {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--brand-highlight);
    display: inline-block;
    padding: 0.4rem 1rem;
    background: rgba(255, 255, 255, 0.08);
    border-left: 3px solid var(--brand-highlight);
  }
  .pp-title {
    font-size: 2rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    line-height: 1.1;
    color: #fff;
    margin-bottom: 1rem;
  }
  @media (min-width: 768px) {
    .pp-title { font-size: 2.5rem; }
  }
  .pp-divider {
    width: 3rem;
    height: 3px;
    background: var(--brand-highlight);
    margin: 0 auto 1.25rem;
  }
  .pp-desc {
    font-size: 0.95rem;
    line-height: 1.75;
    color: rgba(255, 255, 255, 0.7);
  }

  /* ─── Grid ─── */
  .pp-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    max-width: 76rem;
    margin: 0 auto;
  }

  @media (min-width: 768px) {
    .pp-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 2rem;
    }
  }

  /* ─── Card ─── */
  .pp-card {
    position: relative;
    background: #ffffff;
    overflow: hidden;
    transition: all 0.25s ease;
    display: flex;
    flex-direction: column;
  }
  .pp-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.1);
  }

  /* Featured card */
  .pp-card--featured {
    border: 3px solid var(--brand-highlight);
    border-style: solid;
  }

  @media (min-width: 768px) {
    .pp-card--featured {
      transform: scale(1.08);
      z-index: 2;
    }
    .pp-card--featured:hover {
      transform: scale(1.08) translateY(-2px);
    }
  }

  /* ─── Diagonal Corner ─── */
  .pp-corner {
    position: absolute;
    top: 0;
    left: 0;
    width: 0;
    height: 0;
    border-style: solid;
    border-width: 110px 110px 0 0;
    border-color: var(--brand-highlight) transparent transparent transparent;
    z-index: 5;
    overflow: visible;
  }
  .pp-corner-label {
    position: absolute;
    top: -88px;
    left: 12px;
    color: #ffffff;
    font-size: 0.6rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    transform: rotate(-45deg);
    white-space: nowrap;
    line-height: 1;
    max-width: 90px;
    overflow: visible;
  }

  /* ─── Card Inner ─── */
  .pp-card-inner {
    position: relative;
    padding: 4rem 2rem 2rem 2rem;
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  @media (min-width: 768px) {
    .pp-card-inner {
      padding: 4rem 2.5rem 2.5rem 2.5rem;
    }
  }

  /* ─── Content ─── */
  .pp-content {
    flex: 1;
    padding-left: 2rem;
    display: flex;
    flex-direction: column;
  }

  .pp-plan-title {
    font-size: 0.95rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    line-height: 1.25;
    color: #2d2d2d;
    margin-bottom: 1.5rem;
  }

  /* ─── Price Block ─── */
  .pp-price-block {
    display: flex;
    align-items: baseline;
    gap: 0.25rem;
    margin-bottom: 1.25rem;
  }
  .pp-price {
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 2.75rem;
    font-weight: 900;
    line-height: 1;
    color: var(--brand-highlight);
  }
  .pp-period {
    font-size: 0.85rem;
    font-weight: 600;
    color: #888;
  }

  /* ─── Separator ─── */
  .pp-sep {
    width: 2rem;
    height: 2px;
    background: var(--brand-highlight);
    margin-bottom: 1.25rem;
  }

  /* ─── Features ─── */
  .pp-features {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .pp-feature {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    font-size: 0.85rem;
    line-height: 1.5;
    color: #555;
    font-weight: 600;
  }
  .pp-feature-dot {
    width: 6px;
    height: 6px;
    background: var(--brand-highlight);
    flex-shrink: 0;
    margin-top: 0.4rem;
  }

  /* ─── Bottom Label ─── */
  .pp-bottom-label {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    padding: 0.75rem 2rem;
    margin: 0 1rem;
    font-size: 0.65rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--brand-highlight);
    border-top: 1px dashed #d0d0d0;
    position: relative;
  }
  
  .pp-scissors-icon {
    color: var(--brand-highlight);
    position: absolute;
    left: 0;
    top: -12px;
    background: #ffffff;
    padding: 0 0.25rem;
  }
  
  .pp-bottom-text {
    display: inline-block;
  }

  /* ─── Responsive ─── */
  @media (max-width: 768px) {
    .pp-grid {
      grid-template-columns: 1fr;
      max-width: 24rem;
    }
    .pp-card-inner {
      padding: 3.5rem 1.5rem 1.75rem 1.5rem;
    }
    .pp-content {
      padding-left: 1.5rem;
    }
    .pp-bottom-label {
      padding: 0.75rem 1.5rem;
      margin: 0 0.75rem;
    }
  }
</style>
