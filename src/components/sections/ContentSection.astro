---
import { getLocationText } from "@/config/site"

interface Props {
  badge?: string;
  title: string;
  description: string;
  features?: string[];
  buttonText?: string;
  buttonHref?: string;
  imagePosition?: "left" | "right";
  images?: string[];
  imageAlts?: string[];
}

const {
  badge,
  title: rawTitle,
  description: rawDescription,
  features: rawFeatures = [],
  buttonText,
  buttonHref,
  imagePosition = "left",
  images = [],
  imageAlts = [],
} = Astro.props;

const title = getLocationText(rawTitle);
const description = getLocationText(rawDescription);
const features = rawFeatures.map(getLocationText);

const DEFAULT_IMAGE = "https://images.unsplash.com/photo-1621905251918-48416bd8575a?w=800&q=80";
const DEFAULT_SECONDARY = "https://cdn.prod.website-files.com/672c783eb245d962f945af09/67ac697f07002b03059c5cf4_hvac-service.jpeg";
const mainImage = DEFAULT_IMAGE;
const secondaryImage = DEFAULT_SECONDARY;
const isRight = imagePosition === "right";
---

<section class="cs-wrapper">
  <!-- SVG clip-path definition -->
  <svg width="0" height="0" style="position: absolute;">
    <defs>
      <clipPath id="customClip" clipPathUnits="objectBoundingBox">
        <path d="M 0.05, 0.05 L 0.95, 0.05 L 0.95, 0.48 L 0.48, 0.48 L 0.48, 0.95 L 0.05, 0.95 Z" />
      </clipPath>
    </defs>
  </svg>

  <div class="container mx-auto px-6 md:px-12 lg:px-16 py-20 md:py-28">
    <div class:list={["cs-section", { "cs-section--flipped": isRight }]}>
    <!-- Full-bleed image side -->
    <div class="cs-image-side" data-animate={isRight ? "fade-left" : "fade-right"}>
      <div class="cs-image-container">
        {mainImage ? (
          <img
            src={mainImage}
            alt={imageAlts[0] || title}
            class="cs-image cs-image-main"
            loading="lazy"
            decoding="async"
          />
        ) : (
          <div class="cs-image cs-image-main cs-image--placeholder">
            <span>Image</span>
          </div>
        )}

        {/* Secondary image bottom-right */}
        <div class="cs-image-secondary-wrapper" data-parallax>
          {secondaryImage ? (
            <img
              src={secondaryImage}
              alt={imageAlts[1] || `${title} - detail`}
              class="cs-image cs-image-secondary"
              loading="lazy"
              decoding="async"
            />
          ) : (
            <div class="cs-image cs-image-secondary cs-image--placeholder">
              <span>Image 2</span>
            </div>
          )}
        </div>
      </div>
    </div>

    <!-- Text side -->
    <div class="cs-text-side" data-animate={isRight ? "fade-right" : "fade-left"} data-animate-delay="200">
      
      <div class="cs-text-inner">
        {badge && (
          <div class="cs-eyebrow">
            <span class="cs-eyebrow-text">{badge}</span>
          </div>
        )}

        <h2 class="cs-title">{title}</h2>

        <div class="cs-divider"></div>

        <p class="cs-desc" set:html={description} />

        {features.length > 0 && (
          <div class="cs-features" data-animate-stagger>
            {features.map((feature) => (
              <div class="cs-feature">
                <span class="cs-feature-dot"></span>
                <span class="cs-feature-text" set:html={feature} />
              </div>
            ))}
          </div>
        )}

        {buttonText && buttonHref && (
          <a href={buttonHref} class="cs-btn">
            {buttonText}
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <path d="M5 12h14M12 5l7 7-7 7" />
            </svg>
          </a>
        )}
      </div>
    </div>
    </div>
  </div>
</section>

<style>
  .cs-wrapper {
    background: var(--background);
    overflow: hidden;
    position: relative;
  }

  /* ─── Layout ─── */
  .cs-section {
    display: grid;
    grid-template-columns: 50% 50%;
    min-height: auto;
    overflow: hidden;
    gap: 2rem;
  }

  .cs-section--flipped {
    direction: rtl;
  }
  .cs-section--flipped > * {
    direction: ltr;
  }

  /* ─── Image side: full bleed ─── */
  .cs-image-side {
    position: relative;
    overflow: hidden;
  }

  .cs-image-container {
    position: relative;
    width: 100%;
    height: 100%;
    min-height: 400px;
    border-left: 3px solid var(--brand-highlight);
  }

  .cs-image-main {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    clip-path: url(#customClip);
  }

  .cs-image-secondary-wrapper {
    position: absolute;
    bottom: 1rem;
    right: 1rem;
    width: 45%;
    height: 45%;
    z-index: 2;
    transition: transform 0.1s ease-out;
    will-change: transform;
  }

  .cs-image-secondary {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }

  .cs-section--flipped .cs-image-secondary-wrapper {
    right: auto;
    left: 1rem;
  }

  .cs-image--placeholder {
    background: var(--brand-tertiary);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--muted-foreground);
    font-size: 0.875rem;
  }

  /* ─── Text side ─── */
  .cs-text-side {
    position: relative;
    display: flex;
    align-items: center;
    padding: 2rem 0;
  }

  @media (min-width: 1024px) {
    .cs-text-side {
      padding: 2rem 0;
    }
  }

  .cs-text-inner {
    max-width: 560px;
  }

  /* Eyebrow */
  .cs-eyebrow {
    margin-bottom: 1.25rem;
  }
  .cs-eyebrow-text {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--brand-highlight);
    display: inline-block;
    padding: 0.4rem 1rem;
    background: var(--brand-primary);
  }

  /* Title */
  .cs-title {
    font-size: 2rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    line-height: 1.15;
    color: var(--brand-primary);
    margin-bottom: 1.25rem;
  }
  @media (min-width: 768px) {
    .cs-title { font-size: 2.25rem; }
  }
  @media (min-width: 1280px) {
    .cs-title { font-size: 2.5rem; }
  }

  /* Divider */
  .cs-divider {
    width: 3rem;
    height: 3px;
    background: var(--brand-highlight);
    margin-bottom: 1.5rem;
  }

  /* Description */
  .cs-desc {
    font-size: 0.9rem;
    line-height: 1.8;
    color: var(--brand-secondary);
    margin-bottom: 2rem;
  }

  /* ─── Features: vertical list ─── */
  .cs-features {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    margin-bottom: 2rem;
    border-left: 2px solid var(--brand-tertiary);
    padding-left: 0;
  }

  .cs-feature {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.6rem 1rem;
    border-left: 2px solid transparent;
    margin-left: -2px;
    transition: all 0.25s ease;
  }

  .cs-feature:hover {
    border-left-color: var(--brand-highlight);
    background: var(--brand-tertiary);
  }

  .cs-feature-dot {
    width: 6px;
    height: 6px;
    background: var(--brand-highlight);
    flex-shrink: 0;
    transition: transform 0.25s ease;
  }

  .cs-feature:hover .cs-feature-dot {
    transform: scale(1.5);
  }

  .cs-feature-text {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--brand-primary);
  }

  /* ─── CTA ─── */
  .cs-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    padding: 0.7rem 1.75rem;
    background: var(--brand-highlight);
    color: #0a0a0a;
    font-weight: 700;
    font-size: 0.8rem;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    transition: all 0.3s ease;
  }
  .cs-btn:hover {
    filter: brightness(1.08);
    transform: translateX(4px);
  }
  .cs-btn svg {
    transition: transform 0.3s ease;
  }
  .cs-btn:hover svg {
    transform: translateX(4px);
  }

  /* ─── Responsive ─── */
  @media (max-width: 768px) {
    .cs-section {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    .cs-section--flipped {
      direction: ltr;
    }
    .cs-image-container {
      min-height: 300px;
    }
    .cs-image-secondary-wrapper {
      width: 40%;
      bottom: 1rem;
      right: 1rem;
    }
    .cs-text-side {
      padding: 0;
    }
  }
</style>

<script>
  function initParallax() {
    const parallaxElements = document.querySelectorAll<HTMLElement>('[data-parallax]');
    
    function handleScroll() {
      parallaxElements.forEach((el) => {
        const rect = el.getBoundingClientRect();
        const scrollProgress = (window.innerHeight - rect.top) / (window.innerHeight + rect.height);
        
        if (scrollProgress >= 0 && scrollProgress <= 1) {
          const translateY = (scrollProgress - 0.5) * 30;
          el.style.transform = `translateY(${translateY}px)`;
        }
      });
    }

    window.addEventListener('scroll', handleScroll, { passive: true });
    handleScroll();
  }

  initParallax();
  document.addEventListener('astro:page-load', initParallax);
</script>
