---
import { Image } from "astro:assets";
import { getLocationText } from "@/config/site"

interface Coupon {
  icon?: string;
  label: string;
  discount: string;
  description: string;
  buttonText?: string;
  buttonHref?: string;
  backgroundImage?: string;
}

interface Props {
  title?: string;
  coupons: Coupon[];
  backgroundImage?: string;
}

const {
  title: rawTitle = "Specials and Offers",
  coupons,
  backgroundImage,
} = Astro.props;

const title = getLocationText(rawTitle);
const centerIndex = Math.floor(coupons.length / 2);

const defaultBackgrounds = [
  'https://www.calveyheatingandair.com/wp-content/uploads/2021/07/cleaning-air-ducts.png',
  'https://shiptons.ca/wp-content/uploads/2023/05/Air-Conditioning-Maintenance-Service.webp',
  'https://allrite.ca/blogs/image/benefits-of-a-yearly-furnace-tune-up.jpg'
];
---

<section class="cpn-section relative overflow-hidden py-24 md:py-32">
  <!-- Light background with subtle pattern -->
  <div class="absolute inset-0 bg-gradient-to-br from-white via-gray-50 to-blue-50"></div>
  <div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(circle at 1px 1px, rgba(10,37,64,0.15) 1px, transparent 0); background-size: 20px 20px;"></div>
  
  <div class="relative z-[1] container mx-auto px-6 md:px-12 lg:px-16">
    <!-- Section header -->
    <div class="mb-16 text-center" data-animate="fade-scale">
      <div class="inline-flex items-center gap-3 mb-4 px-6 py-2 bg-brand-primary/5 backdrop-blur-sm rounded-full border border-brand-highlight/20">
        <svg class="w-4 h-4 text-brand-highlight" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"/>
        </svg>
        <span class="text-xs font-bold uppercase tracking-[0.25em] text-brand-highlight">Limited Time Offers</span>
      </div>
      <h2 class="text-4xl md:text-5xl lg:text-6xl font-black uppercase tracking-tight text-brand-primary mb-3">{title}</h2>
    </div>

    <!-- Coupons grid -->
    <div class="cpn-grid" data-animate-stagger>
      {coupons.map((coupon, i) => {
        const colors = [
          { bg: 'var(--brand-highlight)', text: '#FFFFFF' }, // orange
          { bg: '#1E88E5', text: '#FFFFFF' },                // bright blue
        ];
        const color = colors[i % colors.length];
        
        return (
          <div class="cpn-ticket-wrapper">
            <div class="cpn-ticket" style={`--ticket-bg: ${color.bg}; --ticket-text: ${color.text};`}>
              <!-- Left section: main content -->
              <div class="cpn-ticket-main">
                <!-- Main content area -->
                <div class="cpn-ticket-content">
                  <!-- Vertical "GIFT FOR YOU" text -->
                  <div class="cpn-ticket-side-text">
                    <span>GIFT FOR YOU</span>
                  </div>
                  
                  <div>
                    <div class="cpn-ticket-inner">
                    <!-- Discount box -->
                    <div class="cpn-ticket-discount-box">
                      <span class="cpn-ticket-discount">{coupon.discount}</span>
                    </div>

                    <!-- Coupon label -->  
                    <div class="cpn-ticket-label">COUPON</div>
                    
                  </div>
                  <p class="coupon-desc">{coupon.description}</p>
                  </div>
                  
                </div>
              </div>
              
              <!-- Right section: barcode stub (clickable) -->
              <a href={coupon.buttonHref || "/contact"} class="cpn-ticket-stub">
                <!-- Barcode -->
                <div class="cpn-ticket-barcode">
                  <div class="cpn-barcode-lines">
                    <div class="cpn-barcode-line" style="height: 2px;"></div>
                    <div class="cpn-barcode-line" style="height: 3px;"></div>
                    <div class="cpn-barcode-line" style="height: 2px;"></div>
                    <div class="cpn-barcode-line" style="height: 4px;"></div>
                    <div class="cpn-barcode-line" style="height: 3px;"></div>
                    <div class="cpn-barcode-line" style="height: 2px;"></div>
                    <div class="cpn-barcode-line" style="height: 4px;"></div>
                    <div class="cpn-barcode-line" style="height: 2px;"></div>
                    <div class="cpn-barcode-line" style="height: 3px;"></div>
                    <div class="cpn-barcode-line" style="height: 2px;"></div>
                    <div class="cpn-barcode-line" style="height: 4px;"></div>
                    <div class="cpn-barcode-line" style="height: 3px;"></div>
                    <div class="cpn-barcode-line" style="height: 2px;"></div>
                    <div class="cpn-barcode-line" style="height: 3px;"></div>
                    <div class="cpn-barcode-line" style="height: 4px;"></div>
                  </div>
                </div>
                <div class="cpn-ticket-code">{coupon.buttonText || "CLAIM"}</div>
              </a>
            </div>
          </div>
        );
      })}
    </div>
  </div>
</section>

<style>
  /* ─── Grid ─── */
  .cpn-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 300px), 1fr));
    gap: clamp(2rem, 5vw, 6rem);
    max-width: 90rem;
    margin: 0 auto;
    justify-items: center;
  }

  /* ─── Wrapper to contain ticket + stub ─── */
  .cpn-ticket-wrapper {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    width: 100%;
    max-width: min(400px, calc(100vw - 4rem));
  }

  /* Scale middle coupon */
  .cpn-ticket-wrapper:nth-child(2) {
    transform: scale(1.1);
    z-index: 2;
  }

  /* ─── Ticket Container ─── */
  .cpn-ticket {
    position: relative;
    display: flex;
    transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1), filter 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    padding-right: clamp(50px, 12vw, 80px);
    width: 100%;
    filter: drop-shadow(0 8px 16px rgba(0, 0, 0, 0.15)) drop-shadow(0 4px 6px rgba(0, 0, 0, 0.1));
  }

  .cpn-ticket-wrapper:hover .cpn-ticket {
    transform: translateY(-8px);
    filter: drop-shadow(0 20px 40px rgba(0, 0, 0, 0.25)) drop-shadow(0 8px 16px rgba(0, 0, 0, 0.15));
  }

  /* ─── Ticket Main Body ─── */
  .cpn-ticket-main {
    position: relative;
    display: flex;
    background: var(--ticket-bg);
    height: clamp(260px, 25vw, 340px);
    overflow: hidden;
    flex: 1;
    min-width: 0;
    mask: radial-gradient(circle 25px at 0px 50%, transparent 25px, black 26px);
  }

  /* ─── Side Text (vertical) ─── */
  .cpn-ticket-side-text {
    writing-mode: vertical-rl;
    text-orientation: mixed;
    padding: clamp(0.75rem, 2.5vw, 2rem) clamp(0.4rem, 0.8vw, 0.75rem);
    display: flex;
    align-items: center;
    justify-content: center;
    transform: rotate(180deg);
    min-width: clamp(45px, 9vw, 65px);
    flex-shrink: 0;
  }

  .cpn-ticket-side-text span {
    font-size: clamp(0.75rem, 1.4vw, 1.3rem);
    font-weight: 900;
    letter-spacing: 0.49em;
    text-transform: uppercase;
    color: var(--ticket-text);
    opacity: 0.9;
    white-space: nowrap;
  }

  @media (max-width: 768px) {
    .cpn-ticket-side-text span {
      letter-spacing: 0.2em;
    }
  }

  /* ─── Main Content ─── */
  .cpn-ticket-content {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: clamp(0.75rem, 2.5vw, 2rem);
    gap: 0;
    min-width: 0;
  }

  .cpn-ticket-inner {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-width: 0;
  }

  .cpn-ticket-discount-box {
    background: rgba(0, 0, 0, 0.85);
    padding: clamp(0.4rem, 1.2vw, 1.5rem) clamp(0.75rem, 2.2vw, 2.5rem);
    border-radius: clamp(4px, 0.8vw, 8px);
    border: 2px solid var(--ticket-text);
  }

  .cpn-ticket-discount {
    font-size: clamp(1.5rem, 3.5vw, 3.2rem);
    font-weight: 900;
    color: var(--ticket-bg);
    line-height: 1;
    text-transform: uppercase;
    letter-spacing: -0.02em;
    text-shadow: 0 2px 4px rgba(0,0,0,0.2);
  }

  .cpn-ticket-label {
    font-size: clamp(1.1rem, 2.3vw, 2.3rem);
    font-weight: 900;
    color: var(--ticket-text);
    text-transform: uppercase;
    letter-spacing: -0.01em;
    margin-top: clamp(0.2rem, 0.6vw, 0.5rem);
  }

  .coupon-desc {
    font-size: clamp(0.75rem, 1.2vw, 0.9rem);
    font-weight: 500;
    color: var(--ticket-text);
    text-align: center;
    line-height: 1.4;
    margin-top: clamp(0.5rem, 1vw, 0.75rem);
    opacity: 0.85;
    max-width: 90%;
  }

  /* ─── Stub (barcode section - now clickable button) ─── */
  .cpn-ticket-stub {
    position: absolute;
    right: 0;
    top: 0;
    width: clamp(50px, 12vw, 80px);
    height: clamp(260px, 25vw, 340px);
    background: rgba(255, 255, 255, 0.95);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: clamp(0.75rem, 2vw, 1.5rem) clamp(0.3rem, 1vw, 0.5rem);
    text-decoration: none;
    cursor: pointer;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    transform-origin: bottom center;
    overflow: hidden;
    mask: radial-gradient(circle 25px at 100% 50%, transparent 25px, black 26px);
  }

  /* Hover: rip-off effect (top part lifts + twists) */
  .cpn-ticket-wrapper:hover .cpn-ticket-stub {
    transform: perspective(400px) rotateX(-5deg) rotateZ(2deg) translateY(-6px) translateX(3px);
    box-shadow: 0 15px 40px rgba(0, 0, 0, 0.4), 0 -5px 15px rgba(0, 0, 0, 0.2);
  }

  .cpn-ticket-stub:hover {
    background: rgba(255, 255, 255, 1);
  }

  /* Perforated line */
  .cpn-ticket-stub::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 2px;
    background: repeating-linear-gradient(
      to bottom,
      rgba(0, 0, 0, 0.2) 0px,
      rgba(0, 0, 0, 0.2) 8px,
      transparent 8px,
      transparent 16px
    );
    z-index: 1;
  }

  .cpn-ticket-barcode {
    display: flex;
    flex-direction: row;
    gap: clamp(0.25rem, 0.5vw, 0.5rem);
    align-items: center;
    width: 60%;
    height: auto;
    max-height: 70%;
    transform: none;
    flex: 1;
    justify-content: center;
    padding: 0;
  }

  .cpn-barcode-lines {
    display: flex;
    flex-direction: column;
    gap: clamp(2px, 0.4vw, 3px);
    align-items: stretch;
    flex: 1;
  }

  .cpn-barcode-line {
    width: 60%;
    background: #1A1A1A;
  }
  
  .cpn-barcode-numbers {
    display: flex;
    flex-direction: column;
    gap: clamp(2px, 0.4vw, 3px);
    align-items: flex-start;
    justify-content: space-between;
    height: 100%;
  }
  
  .cpn-barcode-numbers span {
    font-size: clamp(0.4rem, 0.8vw, 0.6rem);
    font-family: 'Courier New', monospace;
    color: #666;
    line-height: 1;
  }

  .cpn-ticket-code {
    position: absolute;
    bottom: clamp(0.5rem, 1.5vw, 1rem);
    left: 50%;
    transform: translateX(-50%);
    font-size: clamp(0.5rem, 1vw, 0.7rem);
    font-family: system-ui, sans-serif;
    font-weight: 700;
    color: var(--brand-primary);
    writing-mode: horizontal-tb;
    text-orientation: mixed;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    white-space: nowrap;
  }

  /* ─── Details Below Ticket ─── */
  /* Removed - description now inside ticket */

  /* ─── Responsive ─── */
  @media (max-width: 1024px) {
    .cpn-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 4rem;
    }
  }

  @media (max-width: 768px) {
    .cpn-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
    
    .cpn-ticket-wrapper {
      max-width: 100%;
    }
    
    .cpn-ticket {
      padding-right: 70px;
    }
    
    .cpn-ticket-main {
      height: 200px;
    }
    
    .cpn-ticket-stub {
      width: 70px;
      height: 200px;
    }
    
    .cpn-ticket-discount {
      font-size: 2.5rem;
    }
    
    .cpn-ticket-label {
      font-size: 2rem;
    }
    
    .cpn-ticket-side-text span {
      font-size: 1rem;
    }
  }

  @media (max-width: 640px) {
    .cpn-ticket {
      padding-right: 60px;
    }
    
    .cpn-ticket-main {
      height: 180px;
    }
    
    .cpn-ticket-stub {
      width: 60px;
      height: 180px;
    }
    
    .cpn-ticket-discount {
      font-size: 2rem;
    }
    
    .cpn-ticket-label {
      font-size: 1.5rem;
    }
  }
</style>
