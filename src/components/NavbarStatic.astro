---
import { siteConfig } from "@/config/site"
import { utilityNavItems, mainNavItems, quickActions } from "@/config/navigation"
---

<!-- Hidden checkbox — CSS-only mobile drawer toggle, zero JS -->
<input type="checkbox" id="nb-mobile-toggle" class="nb-mobile-toggle-input" aria-hidden="true" />

<header class="nb-header">
  <!-- ── Row 1: Dark top bar (desktop only) ── -->
  <div class="nb-top">
    <div class="container mx-auto px-6 md:px-12 lg:px-16">
      <div class="nb-top-inner">
        <a href="/" class="nb-logo" aria-label={`${siteConfig.business.name} - Home`}>
          <img src={siteConfig.logo.src} alt={siteConfig.logo.alt} class="nb-logo-img" width="44" height="44" decoding="async" loading="eager" />
          <span class="nb-logo-name">{siteConfig.business.name}</span>
        </a>
        <nav class="nb-utility" aria-label="Utility navigation">
          {utilityNavItems.map((item) => (
            item.children ? (
              <div class="nb-util-dropdown">
                <a href={item.href} class="nb-util-link">
                  {item.title}
                  <svg class="nb-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M6 9l6 6 6-6"/></svg>
                </a>
                <div class="nb-util-panel">
                  <div class="nb-util-panel-bar"></div>
                  {item.children.map((child) => (
                    <a href={child.href} class="nb-util-child">{child.title}</a>
                  ))}
                </div>
              </div>
            ) : (
              <a href={item.href} class="nb-util-link">{item.title}</a>
            )
          ))}
        </nav>
      </div>
    </div>
  </div>

  <!-- ── Row 2: Service bar ── -->
  <div class="nb-bar">
    <div class="container mx-auto px-6 md:px-12 lg:px-16">
      <div class="nb-bar-inner">

        <!-- Desktop service nav with CSS mega menus -->
        <nav class="nb-service-nav" aria-label="Service navigation">
          {mainNavItems.map((item) => (
            <div class="nb-nav-item">
              <a href={item.href} class="nb-nav-link">
                {item.title}
                <svg class="nb-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M6 9l6 6 6-6"/></svg>
              </a>
              <span class="nb-nav-underline" aria-hidden="true"></span>
              <div class="nb-mega" role="region" aria-label={`${item.title} submenu`}>
                <div class="nb-mega-bar"></div>
                <div class="nb-mega-inner">
                  <div class="nb-mega-links">
                    {item.categories.flatMap((cat) => cat.items).map((service) => (
                      <a href={service.href} class="nb-mega-link">
                        <span class="nb-mega-dot" aria-hidden="true"></span>
                        {service.title}
                      </a>
                    ))}
                  </div>
                  <div class="nb-mega-footer">
                    <a href={item.href} class="nb-mega-view-all">
                      View all {item.title.toLowerCase()}
                      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
                    </a>
                  </div>
                </div>
              </div>
            </div>
          ))}
        </nav>

        <!-- Desktop quick actions + phone -->
        <div class="nb-actions">
          {quickActions.map((action) => (
            <a href={action.href} class="nb-action-btn" title={action.title}>
              {action.icon === "settings" ? (
                <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z"/></svg>
              ) : (
                <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg>
              )}
              <span>{action.title}</span>
            </a>
          ))}
          <a href={`tel:${siteConfig.contact.phone}`} class="nb-phone-btn">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
            {siteConfig.contact.phoneFormatted}
          </a>
        </div>

        <!-- Mobile: logo + hamburger label (CSS toggle, no JS) -->
        <a href="/" class="nb-mobile-logo" aria-label={`${siteConfig.business.name} - Home`}>
          <img src={siteConfig.logo.src} alt={siteConfig.logo.alt} class="h-9 w-9 object-contain" width="36" height="36" decoding="async" loading="eager" />
          <span class="nb-mobile-name">{siteConfig.business.name}</span>
        </a>
        <label for="nb-mobile-toggle" class="nb-hamburger" aria-label="Open menu" role="button" tabindex="0">
          <svg class="nb-ham-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
          <svg class="nb-close-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </label>
      </div>
    </div>
  </div>
</header>

<!-- Mobile drawer — pure CSS, no JS, no React -->
<div class="nb-mobile-drawer" id="mobile-nav" role="dialog" aria-label="Mobile navigation">
  <!-- Backdrop -->
  <label for="nb-mobile-toggle" class="nb-backdrop" aria-hidden="true"></label>

  <!-- Drawer panel -->
  <div class="nb-drawer-panel">
    <!-- Phone CTA -->
    <a href={`tel:${siteConfig.contact.phone}`} class="nb-drawer-phone">
      <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
      {siteConfig.contact.phoneFormatted}
    </a>

    <!-- Utility links -->
    <div class="nb-drawer-section nb-drawer-section--muted">
      {utilityNavItems.map((item) => (
        item.children ? (
          <details class="nb-drawer-details">
            <summary class="nb-drawer-summary">
              {item.title}
              <svg class="nb-drawer-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
            </summary>
            <div class="nb-drawer-children">
              {item.children.map((child) => (
                <a href={child.href} class="nb-drawer-child">{child.title}</a>
              ))}
            </div>
          </details>
        ) : (
          <a href={item.href} class="nb-drawer-link">{item.title}</a>
        )
      ))}
    </div>

    <!-- Services -->
    <div class="nb-drawer-section nb-drawer-section--white">
      <p class="nb-drawer-section-label">Services</p>
      {mainNavItems.map((service) => (
        <details class="nb-drawer-details">
          <summary class="nb-drawer-summary">
            {service.title}
            <svg class="nb-drawer-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
          </summary>
          <div class="nb-drawer-children">
            {service.categories.flatMap((cat) => cat.items).map((link) => (
              <a href={link.href} class="nb-drawer-child">{link.title}</a>
            ))}
          </div>
        </details>
      ))}
    </div>

    <!-- Quick actions -->
    <div class="nb-drawer-actions">
      {quickActions.map((action, i) => (
        <a href={action.href} class={`nb-drawer-action ${i > 0 ? "nb-drawer-action--border" : ""}`}>
          {action.icon === "settings" ? (
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z"/></svg>
          ) : (
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg>
          )}
          {action.title}
        </a>
      ))}
    </div>
  </div>
</div>

<style>
  /* ── Modern Professional Navbar Styles ── */
  /* Uses global.css design system variables */
  
  /* ── Toggle input (hidden, drives CSS state) ── */
  .nb-mobile-toggle-input {
    position: fixed;
    opacity: 0;
    pointer-events: none;
    width: 0; height: 0;
  }

  /* ── Header ── */
  .nb-header {
    position: sticky;
    top: 0;
    z-index: 50;
    width: 100%;
    font-family: 'Inter', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    backdrop-filter: blur(12px);
    box-shadow: 0 1px 3px rgba(10, 37, 64, 0.08);
  }

  /* ── Top bar (desktop only) ── */
  .nb-top {
    display: none;
    background: var(--brand-primary);
    border-bottom: 1px solid color-mix(in srgb, var(--brand-highlight) 30%, transparent);
  }
  @media (min-width: 1024px) { .nb-top { display: block; } }

  .nb-top-inner {
    display: flex;
    height: 64px;
    align-items: center;
    justify-content: space-between;
  }
  .nb-logo {
    display: flex;
    align-items: center;
    gap: 0.875rem;
    flex-shrink: 0;
    text-decoration: none;
    cursor: pointer;
    transition: transform 0.2s ease;
  }
  .nb-logo:hover {
    transform: translateY(-1px);
  }
  .nb-logo-img {
    height: 40px; width: 40px;
    object-fit: contain;
    filter: brightness(0) invert(1);
    transition: filter 0.2s ease;
  }
  .nb-logo-name {
    font-family: 'Inter', sans-serif;
    font-size: 0.95rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    color: #fff;
    transition: color 0.2s ease;
  }
  .nb-logo:hover .nb-logo-name {
    color: var(--brand-highlight);
  }
  .nb-utility {
    display: flex;
    align-items: center;
    gap: 2rem;
  }
  .nb-util-link {
    font-size: 0.8125rem;
    letter-spacing: 0.02em;
    color: rgba(255,255,255,0.8);
    text-decoration: none;
    font-weight: 500;
    display: flex;
    align-items: center;
    gap: 0.375rem;
    transition: color 0.2s ease;
    cursor: pointer;
    position: relative;
  }
  .nb-util-link::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    right: 0;
    height: 2px;
    background: var(--brand-highlight);
    transform: scaleX(0);
    transition: transform 0.2s ease;
  }
  .nb-util-link:hover {
    color: #fff;
  }
  .nb-util-link:hover::after {
    transform: scaleX(1);
  }
  .nb-chevron {
    width: 0.75rem;
    height: 0.75rem;
    flex-shrink: 0;
    transition: transform 0.2s ease;
  }
  .nb-util-dropdown:hover .nb-chevron {
    transform: rotate(180deg);
  }
  .nb-util-dropdown { position: relative; }
  .nb-util-panel {
    display: none;
    position: absolute;
    right: 0;
    background: #fff;
    box-shadow: 0 10px 40px color-mix(in srgb, var(--brand-primary) 30%, transparent), 0 0 0 1px color-mix(in srgb, var(--brand-primary) 10%, transparent);
    border-radius: 8px;
    padding: 0.5rem;
    min-width: 220px;
    z-index: 40;
    animation: slideDown 0.2s ease;
  }
  @keyframes slideDown {
    from {
      opacity: 0;
      transform: translateY(-8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .nb-util-panel-bar {
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    background: var(--brand-highlight);
    border-radius: 8px 8px 0 0;
  }
  .nb-util-dropdown:hover .nb-util-panel { display: block; }
  .nb-util-child {
    display: block;
    padding: 0.75rem 1rem;
    font-size: 0.875rem;
    color: var(--brand-primary);
    text-decoration: none;
    font-weight: 500;
    border-radius: 6px;
    transition: all 0.2s ease;
    cursor: pointer;
  }
  .nb-util-child:hover {
    color: var(--brand-secondary);
    background: var(--brand-tertiary);
  }

  /* ── Service bar ── */
  .nb-bar {
    background: rgba(255, 255, 255, 0.98);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid color-mix(in srgb, var(--brand-secondary) 15%, var(--brand-tertiary));
  }
  .nb-bar-inner {
    display: flex;
    height: 72px;
    align-items: center;
    gap: 1.5rem;
  }

  /* Desktop service nav — hidden on mobile */
  .nb-service-nav {
    display: none;
    height: 72px;
    gap: 0.25rem;
    overflow-x: auto;
    scrollbar-width: none;
    flex: 1;
    min-width: 0;
  }
  .nb-service-nav::-webkit-scrollbar {
    display: none;
  }
  @media (min-width: 1280px) { .nb-service-nav { display: flex; } }

  .nb-nav-item {
    position: relative;
    height: 100%;
    display: flex;
    align-items: center;
  }
  .nb-nav-link {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0 0.875rem;
    height: 100%;
    font-family: 'Inter', sans-serif;
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--brand-primary);
    text-decoration: none;
    white-space: nowrap;
    transition: color 0.2s ease;
    cursor: pointer;
    position: relative;
  }
  .nb-nav-link:hover,
  .nb-nav-item:hover .nb-nav-link {
    color: var(--brand-secondary);
  }
  .nb-nav-underline {
    position: absolute;
    bottom: 0;
    left: 0.875rem;
    right: 0.875rem;
    height: 3px;
    background: var(--brand-highlight);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    border-radius: 3px 3px 0 0;
  }
  .nb-nav-item:hover .nb-nav-underline {
    transform: scaleX(1);
  }

  /* Mega menu — CSS hover, no JS */
  .nb-mega {
    display: none;
    position: fixed;
    left: 0;
    right: 0;
    top: 72px;
    z-index: 40;
    box-shadow: 0 20px 60px color-mix(in srgb, var(--brand-primary) 20%, transparent);
    animation: slideDown 0.25s ease;
  }

  .nb-nav-item:hover .nb-mega { display: block; }
  .nb-mega-bar {
    height: 3px;
    background: var(--brand-highlight);
  }
  .nb-mega-inner {
    background: #fff;
    padding: 0.75rem 3rem 1.25rem;
  }
  .nb-mega-links {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0 2.5rem;
    margin-bottom: 0.75rem;
  }
  .nb-mega-link {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.375rem 1rem;
    font-size: 0.875rem;
    color: var(--brand-primary);
    text-decoration: none;
    border-radius: 6px;
    transition: all 0.2s ease;
    cursor: pointer;
  }
  .nb-mega-link:hover {
    color: var(--brand-secondary);
    background: var(--brand-tertiary);
    transform: translateX(4px);
  }
  .nb-mega-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: color-mix(in srgb, var(--brand-secondary) 30%, var(--brand-tertiary));
    flex-shrink: 0;
    transition: all 0.2s ease;
  }
  .nb-mega-link:hover .nb-mega-dot {
    background: var(--brand-secondary);
    box-shadow: 0 0 0 4px color-mix(in srgb, var(--brand-secondary) 15%, transparent);
  }
  .nb-mega-footer {
    padding-top: 1.5rem;
    border-top: 1px solid color-mix(in srgb, var(--brand-secondary) 15%, var(--brand-tertiary));
  }
  .nb-mega-view-all {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    font-family: 'Inter', sans-serif;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--brand-secondary);
    text-decoration: none;
    padding: 0.625rem 1.25rem;
    border-radius: 6px;
    transition: all 0.2s ease;
    cursor: pointer;
  }
  .nb-mega-view-all:hover {
    background: var(--brand-tertiary);
    color: var(--brand-primary);
  }
  .nb-mega-view-all svg {
    transition: transform 0.2s ease;
  }
  .nb-mega-view-all:hover svg {
    transform: translateX(4px);
  }

  /* Desktop actions — hidden on mobile */
  .nb-actions {
    display: none;
    align-items: center;
    gap: 0.75rem;
    margin-left: auto;
    flex-shrink: 0;
  }
  @media (min-width: 1280px) { .nb-actions { display: flex; } }

  .nb-action-btn {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    background: #fff;
    border: 1.5px solid color-mix(in srgb, var(--brand-secondary) 25%, var(--brand-tertiary));
    color: var(--brand-primary);
    padding: 0.75rem 1.5rem;
    font-family: 'Inter', sans-serif;
    font-size: 0.875rem;
    font-weight: 600;
    text-decoration: none;
    white-space: nowrap;
    border-radius: 8px;
    transition: all 0.2s ease;
    cursor: pointer;
  }
  @media (max-width: 1535px) {
    .nb-action-btn {
      padding: 0.625rem 1rem;
      font-size: 0.8125rem;
      gap: 0.5rem;
    }
  }
  @media (max-width: 1400px) {
    .nb-action-btn span {
      display: none;
    }
    .nb-action-btn {
      padding: 0.75rem;
    }
  }
  .nb-action-btn:hover {
    border-color: var(--brand-secondary);
    background: var(--brand-tertiary);
    color: var(--brand-secondary);
    transform: translateY(-1px);
    box-shadow: 0 4px 12px color-mix(in srgb, var(--brand-secondary) 20%, transparent);
  }
  .nb-action-btn svg {
    color: var(--brand-secondary);
    transition: transform 0.2s ease;
  }
  .nb-action-btn:hover svg {
    transform: scale(1.1);
  }
  .nb-phone-btn {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    background: var(--brand-secondary);
    color: #fff;
    padding: 0.875rem 1.75rem;
    font-family: 'Inter', sans-serif;
    font-size: 0.9375rem;
    font-weight: 700;
    text-decoration: none;
    white-space: nowrap;
    border-radius: 8px;
    box-shadow: 0 4px 12px color-mix(in srgb, var(--brand-secondary) 35%, transparent);
    transition: all 0.2s ease;
    cursor: pointer;
  }
  @media (max-width: 1535px) {
    .nb-phone-btn {
      padding: 0.75rem 1.25rem;
      font-size: 0.875rem;
      gap: 0.5rem;
    }
  }
  @media (max-width: 1400px) {
    .nb-phone-btn {
      padding: 0.75rem 1rem;
      font-size: 0.8125rem;
    }
  }
  .nb-phone-btn:hover {
    background: var(--brand-highlight);
    color: var(--brand-primary);
    transform: translateY(-2px);
    box-shadow: 0 6px 20px color-mix(in srgb, var(--brand-highlight) 50%, transparent);
  }
  .nb-phone-btn svg {
    color: #fff;
    transition: all 0.2s ease;
  }
  .nb-phone-btn:hover svg {
    color: var(--brand-primary);
    transform: rotate(15deg) scale(1.1);
  }

  /* ── Mobile logo + hamburger ── */
  .nb-mobile-logo {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-shrink: 0;
    text-decoration: none;
    cursor: pointer;
    transition: transform 0.2s ease;
  }
  .nb-mobile-logo:hover {
    transform: translateY(-1px);
  }
  @media (min-width: 1024px) { .nb-mobile-logo { display: none; } }

  .nb-mobile-name {
    display: none;
    font-family: 'Inter', sans-serif;
    font-size: 0.9375rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    color: var(--brand-primary);
  }
  @media (min-width: 768px) { .nb-mobile-name { display: block; } }

  .nb-hamburger {
    display: flex;
    align-items: center;
    justify-content: center;
    margin-left: auto;
    padding: 0.625rem;
    cursor: pointer;
    color: var(--foreground);
    transition: all 0.2s ease;
    flex-shrink: 0;
    border-radius: 8px;
  }
  @media (min-width: 1280px) { .nb-hamburger { display: none; } }
  .nb-hamburger:hover {
    color: var(--brand-secondary);
    background: var(--muted);
  }
  .nb-ham-icon, .nb-close-icon {
    width: 1.5rem;
    height: 1.5rem;
    transition: transform 0.2s ease;
  }
  .nb-close-icon { display: none; }
  /* Show X when open */
  .nb-mobile-toggle-input:checked ~ header .nb-close-icon {
    display: block;
    animation: rotateIn 0.3s ease;
  }
  .nb-mobile-toggle-input:checked ~ header .nb-ham-icon { display: none; }
  @keyframes rotateIn {
    from {
      transform: rotate(-90deg);
      opacity: 0;
    }
    to {
      transform: rotate(0);
      opacity: 1;
